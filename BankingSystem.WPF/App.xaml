<Application x:Class="BankingSystem.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmDash="clr-namespace:BankingSystem.WPF.ViewModels.Dashboard"
             xmlns:vmCust="clr-namespace:BankingSystem.WPF.ViewModels.Customers"
             xmlns:vmAcc="clr-namespace:BankingSystem.WPF.ViewModels.Accounts"
             xmlns:vmAuth="clr-namespace:BankingSystem.WPF.ViewModels.Auth"
             xmlns:viewDash="clr-namespace:BankingSystem.WPF.Views.Dashboard"
             xmlns:viewCust="clr-namespace:BankingSystem.WPF.Views.Customers"
             xmlns:viewAcc="clr-namespace:BankingSystem.WPF.Views.Accounts"
             xmlns:viewAuth="clr-namespace:BankingSystem.WPF.Views.Auth"
             xmlns:vmAdmin="clr-namespace:BankingSystem.WPF.ViewModels.Admin"
             xmlns:viewAdmin="clr-namespace:BankingSystem.WPF.Views.Admin"
             xmlns:helpers="clr-namespace:BankingSystem.WPF.Helpers"
             xmlns:viewnewCust="clr-namespace:BankingSystem.WPF.Views.Customers"
             xmlns:vmnewCust="clr-namespace:BankingSystem.WPF.ViewModels.Customers"
             xmlns:viewOldCust="clr-namespace:BankingSystem.WPF.Views.Customers"
             xmlns:vmOldCust="clr-namespace:BankingSystem.WPF.ViewModels.Customers"
             xmlns:vmServices="clr-namespace:BankingSystem.WPF.ViewModels.Services"
             xmlns:viewServices="clr-namespace:BankingSystem.WPF.Views.Services"
             StartupUri="Views/Auth/AuthWindow.xaml">

    <Application.Resources>

        <ResourceDictionary>

            <!-- 🌍 Themes -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Buttons.xaml"/>
                <ResourceDictionary Source="Themes/TextBoxes.xaml"/>
                <ResourceDictionary Source="Themes/Cards.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 🔥 Converters (ADD HERE) -->
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

            <!-- 🔥 DataTemplates -->

            <DataTemplate DataType="{x:Type vmDash:DashboardViewModel}">
                <viewDash:DashboardView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmCust:CustomersViewModel}">
                <viewCust:CustomersView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmAcc:AccountsViewModel}">
                <viewAcc:AccountsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmAuth:LoginViewModel}">
                <viewAuth:LoginView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vmAdmin:LogsViewModel}">
                <viewAdmin:LogsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmnewCust:NewCustomerViewModel}">
                <viewnewCust:NewCustomerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmOldCust:ExistingCustomerViewModel}">
                <viewOldCust:ExistingCustomerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmCust:CustomerDashboardViewModel}">
                <viewCust:CustomerDashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vmServices:ServicesViewModel}">
                <viewServices:ServicesView/>
            </DataTemplate>
        </ResourceDictionary>

    </Application.Resources>

</Application>