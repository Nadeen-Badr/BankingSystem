<Window x:Class="BankingSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Banking System"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
         WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource AppFont}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}"
                Padding="15">

            <StackPanel>

                <!-- App Title -->
                <TextBlock Text="BANK SYSTEM"
                           Style="{StaticResource TitleTextStyle}"
                           Margin="0,10,0,25"
                           HorizontalAlignment="Center"/>

                <!-- Navigation Buttons -->
                <Button Content="Dashboard"
                        Command="{Binding ShowDashboardCommand}"/>

                <Button Content="View Logs"
                        Command="{Binding ShowLogsCommand}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="Accounts"
                        Command="{Binding ShowAccountsCommand}"
                        Visibility="{Binding IsCustomer, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="Services"
                        Command="{Binding ShowServicesCommand}"
                        Visibility="{Binding IsCustomer, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="Profile"
                        Command="{Binding ShowProfileCommand}"
                        Visibility="{Binding IsCustomer, Converter={StaticResource BoolToVisibility}}"/>

                <Button Content="Logout"
                        Command="{Binding ShowLogoutCommand}"
                        Margin="0,25,0,0"
                        Background="{StaticResource SecondaryBrush}"/>

            </StackPanel>

        </Border>

        <!-- MAIN CONTENT -->
        <Border Grid.Column="1"
                Background="{StaticResource BackgroundBrush}"
                Padding="15">

            <ContentControl Content="{Binding CurrentView}"/>

        </Border>

    </Grid>

</Window>