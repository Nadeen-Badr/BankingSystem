<Window x:Class="BankingSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Banking System"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <StackPanel Grid.Column="0"
            Background="{StaticResource PrimaryBrush}"
            Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">

            <TextBlock Text="BANK SYSTEM"
               Foreground="White"
               FontSize="18"
               FontWeight="Bold"
               Margin="5,15"/>

            <!-- COMMON -->
            <Button Content="Dashboard"
            Command="{Binding ShowDashboardCommand}"/>

            <!-- ADMIN ONLY -->
            <Button Content="View Logs"
            Command="{Binding ShowLogsCommand}"
            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>

            <!-- CUSTOMER ONLY -->
            <Button Content="Accounts"
            Command="{Binding ShowAccountsCommand}"
            Visibility="{Binding IsCustomer, Converter={StaticResource BoolToVisibility}}"/>

            <Button Content="Services"
            Command="{Binding ShowServicesCommand}"
            Visibility="{Binding IsCustomer, Converter={StaticResource BoolToVisibility}}"/>

            <Button Content="Profile"
            Command="{Binding ShowProfileCommand}"
            Visibility="{Binding IsCustomer, Converter={StaticResource BoolToVisibility}}"/>

            <!-- LOGOUT -->
            <Button Content="Logout"
            Command="{Binding ShowLogoutCommand}"
            Margin="5,20,5,0"/>

        </StackPanel>

        <!-- MAIN CONTENT -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="10"/>

    </Grid>

</Window>