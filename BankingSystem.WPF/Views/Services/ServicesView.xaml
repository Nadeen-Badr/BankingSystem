<UserControl x:Class="BankingSystem.WPF.Views.Services.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Services"
                   Style="{StaticResource TitleTextStyle}"
                   Margin="0,0,0,20"/>

        <!-- TABS -->
        <TabControl Grid.Row="1"
                    Background="{StaticResource BackgroundBrush}"
                    BorderThickness="0">

            <!-- ================= CERTIFICATES ================= -->
            <TabItem Header="Certificates">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: LIST -->
                    <Border Style="{StaticResource DashboardCard}"
                            Margin="0,0,10,0">

                        <StackPanel>

                            <TextBlock Text="My Certificates"
                                       Style="{StaticResource SectionHeaderTextStyle}"
                                       Margin="0,0,0,15"/>

                            <ListBox ItemsSource="{Binding Certificates}"
                                     SelectedItem="{Binding SelectedCertificate}"
                                     Background="{StaticResource SurfaceBrush}"
                                     BorderThickness="0">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>

                                        <Border Padding="12"
                                                Margin="6"
                                                Background="{StaticResource BackgroundBrush}"
                                                CornerRadius="8">

                                            <StackPanel>

                                                <TextBlock Text="{Binding Id}"
                                                           Style="{StaticResource BodyTextStyle}"/>

                                                <TextBlock Text="{Binding Price, StringFormat=Price: {0} EGP}"
                                                           Style="{StaticResource MutedTextStyle}"/>

                                                <TextBlock Text="{Binding Period}"
                                                           Style="{StaticResource MutedTextStyle}"/>

                                                <TextBlock Text="{Binding InterestRate, StringFormat=Rate: {0:P}}"
                                                           Style="{StaticResource MutedTextStyle}"/>

                                            </StackPanel>

                                        </Border>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>

                            </ListBox>

                        </StackPanel>

                    </Border>

                    <!-- RIGHT: ACTIONS -->
                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardCard}">

                        <StackPanel>

                            <TextBlock Text="Certificate Actions"
                                       Style="{StaticResource SectionHeaderTextStyle}"
                                       Margin="0,0,0,15"/>

                            <TextBlock Text="Price"
                                       Style="{StaticResource MutedTextStyle}"/>

                            <TextBox Text="{Binding CertificatePrice}"
                                     Margin="0,5"/>

                            <TextBlock Text="Period"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,10,0,0"/>

                            <ComboBox ItemsSource="{Binding Periods}"
                                      SelectedItem="{Binding SelectedPeriod}"
                                      Margin="0,5"/>

                            <Button Content="Buy Certificate"
                                    Command="{Binding BuyCertificateCommand}"
                                    Margin="0,10"/>

                            <Button Content="Update Certificate"
                                    Command="{Binding UpdateCertificateCommand}"
                                    Margin="0,5"/>

                            <Button Content="Delete Certificate"
                                    Command="{Binding DeleteCertificateCommand}"
                                    Background="{StaticResource SecondaryBrush}"
                                    Margin="0,5"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </TabItem>

            <!-- ================= CREDIT CARD ================= -->
            <TabItem Header="Credit Card">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <Border Style="{StaticResource DashboardCard}"
                            Margin="0,0,10,0">

                        <StackPanel>

                            <TextBlock Text="My Credit Card"
                                       Style="{StaticResource SectionHeaderTextStyle}"
                                       Margin="0,0,0,15"/>

                            <TextBlock Text="{Binding CardInfo}"
                                       Style="{StaticResource BodyTextStyle}"/>

                        </StackPanel>

                    </Border>

                    <!-- RIGHT -->
                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardCard}">

                        <StackPanel>

                            <TextBlock Text="Credit Card Actions"
                                       Style="{StaticResource SectionHeaderTextStyle}"
                                       Margin="0,0,0,15"/>

                            <TextBlock Text="Cash Limit"
                                       Style="{StaticResource MutedTextStyle}"/>

                            <TextBox Text="{Binding CreditLimit}"
                                     Margin="0,5"/>

                            <Button Content="Create Card"
                                    Command="{Binding CreateCardCommand}"
                                    Margin="0,10"/>

                            <Button Content="Update Limit"
                                    Command="{Binding UpdateLimitCommand}"
                                    Margin="0,5"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </TabItem>

        </TabControl>

    </Grid>

</UserControl>