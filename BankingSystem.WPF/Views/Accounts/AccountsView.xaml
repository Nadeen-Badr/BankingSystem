<UserControl x:Class="BankingSystem.WPF.Views.Accounts.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: ACCOUNTS LIST -->
        <Border Style="{StaticResource DashboardCard}"
                Margin="0,0,10,0">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="My Accounts"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="0,0,0,15"/>

                <!-- LIST -->
                <ListBox ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedAccount}"
                         Background="Transparent"
                         BorderThickness="0">

                    <ListBox.ItemTemplate>
                        <DataTemplate>

                            <Border Padding="12"
                                    Margin="6"
                                    Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="8">

                                <StackPanel>

                                    <TextBlock Text="{Binding Id, StringFormat=Account ID: {0}}"
                                               Style="{StaticResource BodyTextStyle}"/>

                                    <TextBlock Text="{Binding Balance, StringFormat=Balance: {0}}"
                                               Style="{StaticResource MutedTextStyle}"/>

                                    <TextBlock Text="{Binding AccountType, StringFormat=Type: {0}}"
                                               Style="{StaticResource MutedTextStyle}"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>

        </Border>

        <!-- RIGHT: ACTION PANEL -->
        <Border Grid.Column="1"
                Style="{StaticResource DashboardCard}">

            <StackPanel Margin="5">

                <!-- TITLE -->
                <TextBlock Text="Account Actions"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="0,0,0,15"/>

                <!-- CREATE ACTIONS -->
                <Button Content="Create Saving Account"
                        Command="{Binding CreateSavingCommand}"
                        Margin="0,0,0,8"/>

                <Button Content="Create Salary Account"
                        Command="{Binding CreateSalaryCommand}"
                        Margin="0,0,0,15"/>

                <Separator Margin="0,10"/>

                <!-- AMOUNT -->
                <TextBlock Text="Amount"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,10,0,5"/>

                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,15"/>

                <!-- TRANSACTIONS -->
                <Button Content="Deposit"
                        Command="{Binding DepositCommand}"
                        Margin="0,0,0,8"
                        Background="{StaticResource PrimaryBrush}"/>

                <Button Content="Withdraw"
                        Command="{Binding WithdrawCommand}"
                        Margin="0,0,0,15"
                        Background="{StaticResource SecondaryBrush}"/>

                <Separator Margin="0,10"/>

                <!-- CLOSE -->
                <Button Content="Close Account"
                        Command="{Binding CloseAccountCommand}"
                        Background="{StaticResource SurfaceBrush}"
                        Margin="0,10,0,0"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>