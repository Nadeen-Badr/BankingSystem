<UserControl x:Class="BankingSystem.WPF.Views.Accounts.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: ACCOUNTS LIST -->
        <Border Style="{StaticResource DashboardCard}" Margin="0,0,10,0">

            <StackPanel>

                <TextBlock Text="My Accounts"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- FIXED LISTBOX -->
                <ListBox ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedAccount}">

                    <ListBox.ItemTemplate>
                        <DataTemplate>

                            <Border Padding="10"
                                    Margin="5"
                                    Background="{StaticResource SurfaceBrush}">

                                <StackPanel>

                                    <TextBlock Text="{Binding Id, StringFormat=Account ID: {0}}"/>

                                    <TextBlock Text="{Binding Balance, StringFormat=Balance: {0}}"/>

                                    <TextBlock Text="{Binding AccountType, StringFormat=Type: {0}}"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>

        </Border>

        <!-- RIGHT: ACTION PANEL -->
        <Border Grid.Column="1"
                Style="{StaticResource DashboardCard}">

            <StackPanel Margin="10">

                <TextBlock Text="Account Actions"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- CREATE -->
                <Button Content="Create Saving Account"
                        Command="{Binding CreateSavingCommand}"
                        Margin="0,5"/>

                <Button Content="Create Salary Account"
                        Command="{Binding CreateSalaryCommand}"
                        Margin="0,5"/>

                <Separator Margin="10"/>

                <!-- AMOUNT INPUT -->
                <TextBlock Text="Amount" Margin="0,10,0,5"/>

                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <!-- TRANSACTIONS -->
                <Button Content="Deposit"
                        Command="{Binding DepositCommand}"
                        Margin="0,5"/>

                <Button Content="Withdraw"
                        Command="{Binding WithdrawCommand}"
                        Margin="0,5"/>

                <Separator Margin="10"/>

                <!-- CLOSE -->
                <Button Content="Close Account"
                        Command="{Binding CloseAccountCommand}"
                        Margin="0,5"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>