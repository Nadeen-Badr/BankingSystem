<UserControl x:Class="BankingSystem.WPF.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Width="350">

        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                Padding="20">

            <StackPanel>

                <TextBlock Text="BANK LOGIN"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Button Content="Admin"
                        Command="{Binding SelectAdminCommand}"/>

                <Button Content="Existing Customer"
                        Command="{Binding SelectExistingCustomerCommand}"/>

                <Button Content="New Customer"
                        Command="{Binding SelectNewCustomerCommand}"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>