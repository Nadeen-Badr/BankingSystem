<UserControl x:Class="BankingSystem.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Admin Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <!-- CARDS -->
        <UniformGrid Grid.Row="1" Columns="3">

            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Customers"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding TotalCustomers}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Accounts"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding TotalAccounts}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Total Balance"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding TotalBalance}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Certificates"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding TotalCertificates}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Credit Cards"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding TotalCreditCards}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>

</UserControl>