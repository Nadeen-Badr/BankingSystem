<UserControl x:Class="BankingSystem.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Admin Dashboard"
                   Style="{StaticResource TitleTextStyle}"
                   Margin="0,0,0,25"/>

        <!-- CARDS -->
        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Rows="2">

            <!-- Customers -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Customers"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="{Binding TotalCustomers}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Accounts -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Accounts"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="{Binding TotalAccounts}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Total Balance -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Total Balance"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="{Binding TotalBalance}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Certificates -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Certificates"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="{Binding TotalCertificates}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Credit Cards -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Credit Cards"
                               Style="{StaticResource MutedTextStyle}"/>
                    <TextBlock Text="{Binding TotalCreditCards}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>

</UserControl>