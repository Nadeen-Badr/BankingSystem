<UserControl x:Class="BankingSystem.WPF.Views.Customers.ExistingCustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Width="380">

        <Border Style="{StaticResource DashboardCard}">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Select Customer"
                           Style="{StaticResource TitleTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- COMBOBOX LABEL (optional but improves clarity) -->
                <TextBlock Text="Customer"
                           Style="{StaticResource MutedTextStyle}"/>

                <ComboBox ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="Name"
                          Margin="0,5,0,15"
                          Height="32"/>

                <!-- LOGIN -->
                <Button Content="Login"
                        Command="{Binding LoginCommand}"
                        Margin="0,0,0,10"
                        Background="{StaticResource PrimaryBrush}"/>

                <!-- BACK -->
                <Button Content="Back"
                        Command="{Binding BackCommand}"
                        Background="{StaticResource SurfaceBrush}"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>