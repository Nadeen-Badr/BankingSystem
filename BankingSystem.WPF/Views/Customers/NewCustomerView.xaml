<UserControl x:Class="BankingSystem.WPF.Views.Customers.NewCustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Width="380">

        <Border Style="{StaticResource DashboardCard}">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Create New Customer"
                           Style="{StaticResource TitleTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- NAME -->
                <TextBlock Text="Name"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,5"/>
                <TextBox Text="{Binding Name}"/>

                <!-- AGE -->
                <TextBlock Text="Age"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,10,0,5"/>
                <TextBox Text="{Binding Age}"/>

                <!-- ADDRESS -->
                <TextBlock Text="Address"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,10,0,5"/>
                <TextBox Text="{Binding Address}"/>

                <!-- GENDER (RESTORED ORIGINAL WORKING VERSION) -->
                <TextBlock Text="Gender"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,10,0,5"/>

                <ComboBox ItemsSource="{Binding Genders}"
          SelectedItem="{Binding Gender}" />

                <!-- CREATE BUTTON -->
                <Button Content="Create Customer"
                        Command="{Binding CreateCustomerCommand}"
                        Background="{StaticResource PrimaryBrush}"
                        Margin="0,20,0,5"/>

                <!-- BACK BUTTON -->
                <Button Content="Back"
                        Command="{Binding BackCommand}"
                        Background="{StaticResource SurfaceBrush}"/>

                <TextBlock Text="{Binding Message}"
           Foreground="LightGreen"
           FontWeight="Bold"
           Margin="0,10,0,0"
           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>