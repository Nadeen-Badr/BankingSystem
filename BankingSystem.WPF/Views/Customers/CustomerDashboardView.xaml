<UserControl x:Class="BankingSystem.WPF.Views.Customers.CustomerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Customer Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <!-- CARDS -->
        <UniformGrid Grid.Row="1" Columns="2">

            <!-- Total Balance -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Total Balance"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding TotalBalance}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Accounts Count -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Accounts"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding Accounts.Count}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Certificates Count -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Certificates"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding Certificates.Count}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Recent Transactions -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Recent Transactions"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"/>
                    <TextBlock Text="{Binding Transactions.Count}"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>

</UserControl>