<UserControl x:Class="BankingSystem.WPF.Views.Customers.CustomerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="{Binding CustomerName}"
                   FontSize="24"
                   FontWeight="Bold"/>

        <!-- BALANCE -->
        <TextBlock Grid.Row="1"
                   Text="{Binding TotalBalance, StringFormat=Total Balance: {0} EGP}"
                   FontSize="18"
                   Margin="0,10,0,20"/>

        <!-- CONTENT -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ACCOUNTS -->
            <StackPanel>
                <TextBlock Text="Accounts"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2C3E50"
                                    Padding="10"
                                    Margin="5">

                                <StackPanel>
                                    <TextBlock Text="{Binding Id}" Foreground="White"/>
                                    <TextBlock Text="{Binding Balance}" Foreground="White"/>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- TRANSACTIONS -->
            <StackPanel Grid.Column="1">

                <TextBlock Text="Recent Transactions"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ItemsControl ItemsSource="{Binding Transactions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#16A085"
                                    Padding="10"
                                    Margin="5">

                                <StackPanel>
                                    <TextBlock Text="{Binding Type}" Foreground="White"/>
                                    <TextBlock Text="{Binding Amount}" Foreground="White"/>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </Grid>

    </Grid>
</UserControl>