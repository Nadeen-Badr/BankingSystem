<UserControl x:Class="BankingSystem.WPF.Views.Customers.CustomerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="{StaticResource AppFont}">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="Customer Dashboard"
                   Style="{StaticResource TitleTextStyle}"
                   Margin="0,0,0,25"/>

        <!-- CARDS -->
        <UniformGrid Grid.Row="1"
                     Columns="2">

            <!-- Total Balance -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Total Balance"
                               Style="{StaticResource MutedTextStyle}"/>

                    <TextBlock Text="{Binding TotalBalance}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Accounts -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Accounts"
                               Style="{StaticResource MutedTextStyle}"/>

                    <TextBlock Text="{Binding Accounts.Count}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Certificates -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Certificates"
                               Style="{StaticResource MutedTextStyle}"/>

                    <TextBlock Text="{Binding Certificates.Count}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

            <!-- Transactions -->
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="Recent Transactions"
                               Style="{StaticResource MutedTextStyle}"/>

                    <TextBlock Text="{Binding Transactions.Count}"
                               Style="{StaticResource SectionHeaderTextStyle}"
                               FontSize="26"/>
                </StackPanel>
            </Border>

        </UniformGrid>

    </Grid>

</UserControl>