<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="DarkBackgroundColor">#FF2A363B</Color>

    <!-- Surface (Cards / Panels) -->
    <Color x:Key="SurfaceColor">#FF33424A</Color>

    <!-- Primary Accent -->
    <Color x:Key="PrimaryColor">#FFE84A5F</Color>

    <!-- Secondary Accent -->
    <Color x:Key="SecondaryColor">#FFFF847C</Color>

    <!-- Success -->
    <Color x:Key="SuccessColor">#FF99B898</Color>

    <!-- Light Highlight -->
    <Color x:Key="HighlightColor">#FFFECEAB</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#FFCCCCCC</Color>

</ResourceDictionary>